@model ContentHub.Web.ViewModels.CriarFonteViewModel

@{
    ViewData["Title"] = "Nova fonte";
}

<section class="form-page">
    <div class="form-heading">
        <p class="eyebrow">Fonte de conteúdo</p>
        <h1>Salvar perfil</h1>
        <p>Cadastre a origem do conteúdo. Depois você salva o link como post para aparecer no feed.</p>
    </div>

    <form class="content-form" asp-action="NovaFonte" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" placeholder="Ex: Perfil de Tecnologia" />
            <span asp-validation-for="Nome"></span>
        </div>

        <div class="field-group">
            <label asp-for="UrlPerfil"></label>
            <input asp-for="UrlPerfil" placeholder="https://www.instagram.com/perfil" />
            <span asp-validation-for="UrlPerfil"></span>
        </div>

        <div class="field-group">
            <label asp-for="CategoriaId"></label>
            <select asp-for="CategoriaId" asp-items="Model.Categorias">
                <option value="0">Selecione uma categoria</option>
            </select>
            <span asp-validation-for="CategoriaId"></span>
        </div>

        <div class="form-actions">
            <button type="submit">Salvar fonte</button>
            <a asp-controller="Home" asp-action="Index">Voltar ao feed</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
