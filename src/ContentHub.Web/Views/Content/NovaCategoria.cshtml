@model ContentHub.Web.ViewModels.CriarCategoriaViewModel

@{
    ViewData["Title"] = "Nova categoria";
}

<section class="form-page">
    <div class="form-heading">
        <p class="eyebrow">Organização</p>
        <h1>Nova categoria</h1>
        <p>Crie uma categoria para organizar fontes e posts no feed.</p>
    </div>

    <form class="content-form" asp-action="NovaCategoria" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" placeholder="Ex: Esportes, IA, Estudos" />
            <span asp-validation-for="Nome"></span>
        </div>

        <div class="form-actions">
            <button type="submit">Salvar categoria</button>
            <a asp-controller="Content" asp-action="NovaFonte">Nova fonte</a>
            <a asp-controller="Home" asp-action="Index">Voltar ao feed</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
