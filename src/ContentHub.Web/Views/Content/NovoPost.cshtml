@model ContentHub.Web.ViewModels.CriarPostViewModel

@{
    ViewData["Title"] = "Novo post";
}

<section class="form-page">
    <div class="form-heading">
        <p class="eyebrow">Link salvo</p>
        <h1>Salvar post</h1>
        <p>Escolha a fonte, cole o link e adicione uma descrição curta.</p>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <section class="success-notice">
            @successMessage
        </section>
    }

    @if (Model.Fontes.Count == 0)
    {
        <section class="notice">
            <strong>Nenhuma fonte cadastrada.</strong>
            <span>Cadastre uma fonte antes de salvar posts.</span>
        </section>
    }

    <form class="content-form" asp-action="NovoPost" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field-group">
            <label asp-for="FonteId"></label>
            <select asp-for="FonteId" asp-items="Model.Fontes">
                <option value="0">Selecione uma fonte</option>
            </select>
            <span asp-validation-for="FonteId"></span>
        </div>

        <div class="field-group">
            <label asp-for="Url"></label>
            <input asp-for="Url" placeholder="https://www.instagram.com/p/... ou outro link" />
            <span asp-validation-for="Url"></span>
        </div>

        <div class="field-group">
            <label asp-for="Descricao"></label>
            <textarea asp-for="Descricao" rows="5" placeholder="Por que este post foi salvo?"></textarea>
            <span asp-validation-for="Descricao"></span>
        </div>

        <div class="field-group">
            <label asp-for="DataPost"></label>
            <input asp-for="DataPost" />
            <span asp-validation-for="DataPost"></span>
        </div>

        <div class="form-actions">
            <button type="submit" @(Model.Fontes.Count == 0 ? "disabled" : string.Empty)>Salvar post</button>
            <a asp-controller="Content" asp-action="NovaFonte">Nova fonte</a>
            <a asp-controller="Home" asp-action="Index">Voltar ao feed</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
